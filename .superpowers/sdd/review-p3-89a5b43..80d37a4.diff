+name: Scheduled Automation
+
+on:
+  schedule:
+    # Runs at 06:00 UTC daily
+    - cron: '0 6 * * *'
+
+jobs:
+  run:
+    runs-on: ubuntu-latest
+    defaults:
+      run:
+        working-directory: ./worker
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
