{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "bg", "color": "#181817", "name": "Background" },
        { "slug": "panel", "color": "#1e1e1b", "name": "Panel" },
        { "slug": "border", "color": "#2a2824", "name": "Border" },
        { "slug": "text", "color": "#ece8e0", "name": "Text" },
        { "slug": "muted", "color": "#1e1e1b", "name": "Muted" },
        { "slug": "gold", "color": "#c9a84c", "name": "Gold" },
        { "slug": "muted-text", "color": "#8a8678", "name": "Muted Text" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "display",
          "name": "Display",
          "fontFamily": "Syne, ui-sans-serif, system-ui, sans-serif"
        },
        {
          "slug": "sans",
          "name": "Sans-Serif",
          "fontFamily": "'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif"
        },
        {
          "slug": "serif",
          "name": "Serif",
          "fontFamily": "Lora, Georgia, serif"
        },
        {
          "slug": "mono",
          "name": "Monospace",
          "fontFamily": "'IBM Plex Mono', Consolas, monospace"
        }
      ],
      "fluid": true,
      "fontSizes": [
        { "slug": "xs", "size": "0.6875rem", "fluid": { "min": "0.625rem", "max": "0.75rem" } },
        { "slug": "small", "size": "0.8125rem", "fluid": { "min": "0.75rem", "max": "0.875rem" } },
        { "slug": "medium", "size": "1rem", "fluid": { "min": "0.9375rem", "max": "1.0625rem" } },
        { "slug": "large", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.375rem" } },
        { "slug": "x-large", "size": "1.75rem", "fluid": { "min": "1.375rem", "max": "2rem" } },
        { "slug": "xx-large", "size": "2.5rem", "fluid": { "min": "1.75rem", "max": "3rem" } },
        { "slug": "xxx-large", "size": "3.5rem", "fluid": { "min": "2.25rem", "max": "4.25rem" } }
      ],
      "dropCap": false
    },
    "layout": {
      "contentSize": "780px",
      "wideSize": "1560px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--serif)",
      "lineHeight": 1.7
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "lineHeight": 1.1,
          "fontWeight": 700,
          "letterSpacing": "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "lineHeight": 1.2,
          "fontWeight": 700,
          "letterSpacing": "-0.02em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "lineHeight": 1.25,
          "fontWeight": 600
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "lineHeight": 1.3,
          "fontWeight": 600
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--sans)",
          "lineHeight": 1.4,
          "fontWeight": 500
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "lineHeight": 1.4,
          "fontWeight": 400,
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--gold)" },
        ":hover": { "color": { "text": "#d4b96a" } }
      },
      "button": {
        "color": { "background": "var(--wp--preset--color--gold)", "text": "#ffffff" },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--sans)",
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": 600
        },
        "spacing": { "padding": { "top": "0.5rem", "bottom": "0.5rem", "left": "1rem", "right": "1rem" } },
        "border": { "radius": "6px" }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": 700,
          "letterSpacing": "-0.02em"
        },
        "color": { "text": "var(--wp--preset--color--text)" }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": 600,
          "letterSpacing": "-0.01em"
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--xs)",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        },
        "color": { "text": "var(--wp--preset--color--muted)" }
      },
      "core/separator": {
        "color": { "background": "var(--wp--preset--color--border)" },
        "spacing": { "margin": { "top": "1.5rem", "bottom": "1.5rem" } }
      },
      "core/query-pagination": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "core/post-date": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--xs)",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        },
        "color": { "text": "var(--wp--preset--color--muted)" }
      },
      "core/post-terms": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--xs)",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        }
      },
      "core/post-excerpt": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "lineHeight": 1.6
        },
        "color": { "text": "var(--wp--preset--color--muted)" }
      },
      "core/search": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "core/query-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": 700,
          "letterSpacing": "-0.02em"
        }
      }
    }
  },
  "customTemplates": [
    { "name": "submission", "title": "Submission", "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" },
    { "name": "masthead", "title": "Masthead", "area": "uncategorized" },
    { "name": "signals-rail", "title": "Signals Rail", "area": "uncategorized" },
    { "name": "policy-strip", "title": "Policy Strip", "area": "uncategorized" }
  ]
}
