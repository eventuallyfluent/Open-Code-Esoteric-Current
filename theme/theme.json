{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "bg", "color": "#0a0a0a", "name": "Background" },
        { "slug": "bg-dark", "color": "#050505", "name": "Background Dark" },
        { "slug": "panel", "color": "#121212", "name": "Panel" },
        { "slug": "border", "color": "#2a2520", "name": "Border" },
        { "slug": "text", "color": "#e8e3da", "name": "Text" },
        { "slug": "muted", "color": "#8a8580", "name": "Muted" },
        { "slug": "gold", "color": "#c4a45a", "name": "Muted Gold" },
        { "slug": "burgundy", "color": "#4a1a2e", "name": "Deep Burgundy" },
        { "slug": "navy", "color": "#0f1b2d", "name": "Dark Navy" },
        { "slug": "archival", "color": "#d4cfc4", "name": "Archival Tone" },
        { "slug": "light-bg", "color": "#e5e0d5", "name": "Light Background" },
        { "slug": "light-text", "color": "#1a1510", "name": "Light Text" },
        { "slug": "black", "color": "#050505", "name": "Black" },
        { "slug": "white", "color": "#e8e3da", "name": "White" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "serif",
          "name": "Serif",
          "fontFamily": "'Source Serif 4', Georgia, 'Times New Roman', serif"
        },
        {
          "slug": "sans",
          "name": "Sans-Serif",
          "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
        },
        {
          "slug": "mono",
          "name": "Monospace",
          "fontFamily": "'IBM Plex Mono', 'JetBrains Mono', Consolas, monospace"
        }
      ],
      "fluid": true,
      "fontSizes": [
        { "slug": "xs", "size": "0.6875rem", "fluid": { "min": "0.625rem", "max": "0.75rem" } },
        { "slug": "small", "size": "0.8125rem", "fluid": { "min": "0.75rem", "max": "0.875rem" } },
        { "slug": "medium", "size": "1rem", "fluid": { "min": "0.9375rem", "max": "1.0625rem" } },
        { "slug": "large", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.375rem" } },
        { "slug": "x-large", "size": "1.75rem", "fluid": { "min": "1.375rem", "max": "2rem" } },
        { "slug": "xx-large", "size": "2.5rem", "fluid": { "min": "1.75rem", "max": "3rem" } },
        { "slug": "xxx-large", "size": "3.5rem", "fluid": { "min": "2.25rem", "max": "4.25rem" } }
      ],
      "dropCap": false
    },
    "layout": {
      "contentSize": "780px",
      "wideSize": "1560px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "lineHeight": 1.7
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif)",
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "lineHeight": 1.15,
          "fontWeight": 400,
          "letterSpacing": "-0.01em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif)",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "lineHeight": 1.2,
          "fontWeight": 400,
          "letterSpacing": "-0.01em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "lineHeight": 1.25,
          "fontWeight": 400
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif)",
          "lineHeight": 1.3,
          "fontWeight": 400
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--sans)",
          "lineHeight": 1.4,
          "fontWeight": 500
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "lineHeight": 1.4,
          "fontWeight": 400,
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--gold)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--archival)" } }
      },
      "button": {
        "color": { "background": "var(--wp--preset--color--burgundy)", "text": "var(--wp--preset--color--text)" },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--xs)",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        },
        "spacing": { "padding": { "top": "0.625rem", "bottom": "0.625rem", "left": "1.25rem", "right": "1.25rem" } },
        "border": { "radius": "0" }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": 400
        },
        "color": { "text": "var(--wp--preset--color--text)" }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif)",
          "fontWeight": 400
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--xs)",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        },
        "color": { "text": "var(--wp--preset--color--muted)" }
      },
      "core/separator": {
        "color": { "background": "var(--wp--preset--color--border)" },
        "spacing": { "margin": { "top": "1.5rem", "bottom": "1.5rem" } }
      },
      "core/query-pagination": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "core/post-date": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--xs)",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        },
        "color": { "text": "var(--wp--preset--color--muted)" }
      },
      "core/post-terms": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--xs)",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        }
      },
      "core/post-excerpt": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "lineHeight": 1.6
        },
        "color": { "text": "var(--wp--preset--color--muted)" }
      },
      "core/search": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "core/query-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif)",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": 400
        }
      }
    }
  },
  "customTemplates": [
    { "name": "submission", "title": "Submission", "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" },
    { "name": "masthead", "title": "Masthead", "area": "uncategorized" },
    { "name": "signals-rail", "title": "Signals Rail", "area": "uncategorized" },
    { "name": "policy-strip", "title": "Policy Strip", "area": "uncategorized" }
  ]
}
