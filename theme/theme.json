{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "black", "color": "#000000", "name": "Black" },
        { "slug": "warm-white", "color": "#F5F0E8", "name": "Warm White" },
        { "slug": "muted-gold", "color": "#C8A84E", "name": "Muted Gold" },
        { "slug": "deep-burgundy", "color": "#6B1D2F", "name": "Deep Burgundy" },
        { "slug": "dark-navy", "color": "#1A2238", "name": "Dark Navy" },
        { "slug": "charcoal", "color": "#2C2C2C", "name": "Charcoal" },
        { "slug": "light-gray", "color": "#E8E4DC", "name": "Light Gray" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" }
      ],
      "duotone": [
        {
          "slug": "gold-burgundy",
          "colors": [ "#1A2238", "#C8A84E" ],
          "name": "Gold on Navy"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "serif",
          "name": "Serif",
          "fontFamily": "'Playfair Display', Georgia, 'Times New Roman', serif"
        },
        {
          "slug": "sans",
          "name": "Sans-Serif",
          "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
        },
        {
          "slug": "mono",
          "name": "Monospace",
          "fontFamily": "'JetBrains Mono', 'Fira Code', monospace"
        }
      ],
      "fluid": true,
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "fluid": { "min": "0.875rem", "max": "1rem" } },
        { "slug": "medium", "size": "1rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
        { "slug": "large", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.5rem" } },
        { "slug": "x-large", "size": "1.75rem", "fluid": { "min": "1.5rem", "max": "2rem" } },
        { "slug": "xx-large", "size": "2.5rem", "fluid": { "min": "2rem", "max": "3rem" } }
      ],
      "dropCap": false
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1140px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--warm-white)",
      "text": "var(--wp--preset--color--charcoal)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "lineHeight": 1.7
    },
    "elements": {
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--xx-large)", "lineHeight": 1.2 } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--x-large)", "lineHeight": 1.25 } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--large)", "lineHeight": 1.3 } },
      "h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "lineHeight": 1.35 } },
      "h5": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "lineHeight": 1.4 } },
      "h6": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "lineHeight": 1.4 } },
      "link": {
        "color": { "text": "var(--wp--preset--color--deep-burgundy)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--muted-gold)" } }
      },
      "button": {
        "color": { "background": "var(--wp--preset--color--black)", "text": "var(--wp--preset--color--white)" },
        "typography": { "fontFamily": "var(--wp--preset--font-family--sans)" },
        "spacing": { "padding": { "top": "0.75rem", "bottom": "0.75rem", "left": "1.5rem", "right": "1.5rem" } },
        "border": { "radius": "0" }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--serif)", "fontSize": "var(--wp--preset--font-size--x-large)" },
        "color": { "text": "var(--wp--preset--color--white)" }
      },
      "core/post-title": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" }
      },
      "core/navigation": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--small)" },
        "color": { "text": "var(--wp--preset--color--white)" }
      },
      "core/separator": {
        "color": { "background": "var(--wp--preset--color--muted-gold)" },
        "spacing": { "margin": { "top": "2rem", "bottom": "2rem" } }
      },
      "core/query-pagination": {
        "typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontSize": "var(--wp--preset--font-size--small)" }
      }
    }
  },
  "customTemplates": [
    { "name": "submission", "title": "Submission", "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" },
    { "name": "masthead", "title": "Masthead", "area": "uncategorized" },
    { "name": "signals-rail", "title": "Signals Rail", "area": "uncategorized" },
    { "name": "policy-strip", "title": "Policy Strip", "area": "uncategorized" }
  ]
}
